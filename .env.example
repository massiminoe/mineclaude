# Config for the `mineclaude` MCP launcher (loaded from .env at startup).
# The bot is driven over MCP by an external agent (e.g. Claude Code) — there is
# no built-in LLM, so no API keys are needed here. Every value below has a
# working default; copy to .env only to override.

# --- bridge (the native Fabric mod) ---
BRIDGE_URL=http://localhost:8081
BRIDGE_WS_URL=ws://localhost:8082/events
# MOCK_BRIDGE=1            # run without a MC server (in-memory mock bridge)

# --- MCP server (what the driving agent connects to) ---
MCP_HOST=127.0.0.1
MCP_PORT=5556             # tools served at http://MCP_HOST:MCP_PORT/mcp

# --- monitor (observability UI + Console) ---
MONITOR_PORT=5555

LOG_LEVEL=INFO

# Mod-container settings (RECORD_VIDEO, MONITOR_VIDEO_FILTER, etc.) live in
# docker-compose.yml, not here — they configure the MC client container, not
# this process.
