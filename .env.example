# Which model/provider the agent runs on. See agent/providers.py.
#   anthropic   -> Claude via api.anthropic.com   (needs ANTHROPIC_API_KEY)
#   fireworks   -> Kimi K2.6 via Fireworks        (needs FIREWORKS_API_KEY)
#   openrouter  -> Gemini 3.5 Flash via OpenRouter (needs OPENROUTER_API_KEY)
#   gpt5mini    -> GPT-5.4 Mini via OpenRouter, medium reasoning (needs OPENROUTER_API_KEY)
LLM_PROVIDER=anthropic

# --- anthropic provider ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- fireworks provider ---
# FIREWORKS_API_KEY=fw-...
# FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p6

# --- openrouter providers (openrouter / gpt5mini share OPENROUTER_API_KEY) ---
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=google/gemini-3.5-flash   # pins the `openrouter` (gemini) entry only
# GPT5MINI_MODEL=openai/gpt-5.4-mini         # pins the `gpt5mini` entry (separate knob)
# REASONING_EFFORT tunes effort-based providers (gpt5mini): xhigh|high|medium|low|minimal
# REASONING_EFFORT=medium

# Compaction defaults to the main model when unset.
COMPACTION_MODEL=

BRIDGE_URL=http://localhost:8081
BRIDGE_WS_URL=ws://localhost:8082/events
BOT_NAME=Kimi
LOG_LEVEL=INFO
MONITOR_PORT=5555

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

MONITOR_VIDEO_FILTER="eq=gamma=2.0:brightness=0.08:contrast=1.15"
